{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "GITHUB_CLIENT_ID": "@github_client_id",
    "GITHUB_CLIENT_SECRET": "@github_client_secret",
    "GITHUB_CALLBACK_URL": "@github_callback_url",
    "GROQ_API_KEY": "@groq_api_key"
  },
  "functions": {
    "server.js": {
      "maxDuration": 30,
      "memory": 256
    }
  }
}
